{
  "$schema": "https://schema.railpack.com",
  "provider": "node",

  "buildAptPackages": [
    "python3",
    "python3-pip",
    "python3-venv",
    "tesseract-ocr",
    "tesseract-ocr-hin",
    "tesseract-ocr-tel"
  ],

  "steps": {
    "frontend": {
      "commands": [
        "cd frontend && npm install",
        "cd frontend && API_INTERNAL_URL=http://127.0.0.1:8080 npm run build"
      ]
    },
    "node-backend": {
      "commands": [
        "cd services/node-backend && npm install --production"
      ]
    },
    "python-backend": {
      "commands": [
        "python3 -m venv /opt/venv",
        "/opt/venv/bin/pip install --no-cache-dir -r services/python-backend/requirements.txt"
      ]
    }
  },

  "deploy": {
    "aptPackages": [
      "nginx",
      "supervisor",
      "python3",
      "tesseract-ocr",
      "tesseract-ocr-hin",
      "tesseract-ocr-tel"
    ],
    "startCommand": "bash start.sh",
    "variables": {
      "NODE_ENV": "production",
      "PATH": "/opt/venv/bin:/usr/local/bin:/usr/bin:/bin"
    }
  }
}
